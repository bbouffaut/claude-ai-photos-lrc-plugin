{
  "name": "claude-photo-ai-server",
  "version": "2.0.0",
  "description": "Serveur intermédiaire TypeScript pour le plugin Lightroom Claude Photo AI",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "tsx src/test_api.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": ["lightroom", "claude", "anthropic", "photography", "xmp"],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
